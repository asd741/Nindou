# Supabase 連線設定 —— 複製這支檔案為 .env.local 並填入自己的值
#
# 取得方式：Supabase 專案 → 左下 Settings → API
#   VITE_SUPABASE_URL      = 「Project URL」
#   VITE_SUPABASE_ANON_KEY = 「Project API keys」的 anon / public 那把
#
# 這兩個值本來就是設計成公開放在前端的，安全性由資料庫的 RLS 規則保障。
# .env.local 不會被 git 追蹤（見 .gitignore 的 *.local）。

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
